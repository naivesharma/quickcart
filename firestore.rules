// firestore.rules
// Deploy with: firebase deploy --only firestore:rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Any authenticated user can read stores
    // Only store owners (role == 'merchant') can write their own store
    match /stores/{storeId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'merchant' &&
        resource.data.ownerId == request.auth.uid;
    }

    // Store items — readable by all auth users, writable by store owner
    match /stores/{storeId}/items/{itemId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
    }

    // Orders — customer can create, both customer and merchant can read their own
    match /orders/{orderId} {
      allow create: if request.auth != null;
      allow read, update: if request.auth != null && (
        resource.data.customerId == request.auth.uid ||
        resource.data.merchantId == request.auth.uid
      );
    }
  }
}
